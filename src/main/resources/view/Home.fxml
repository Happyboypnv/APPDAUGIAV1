<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="710.0" prefWidth="1200.0" style="-fx-background-color: #1c254b;" stylesheets="@../style/nen.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.controller.HomeController">
   <children>
      <HBox>
         <children>

            <fx:include source="NavbarComponent.fxml" />

            <VBox spacing="25.0" HBox.hgrow="ALWAYS">
               <padding>
                  <Insets bottom="20.0" left="30.0" right="30.0" top="30.0" />
               </padding>
               <children>

                  <Label text="Danh sách phiên đấu giá hiện tại" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="28.0" />
                     </font>
                  </Label>

                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <TextField fx:id="searchField" prefHeight="35.0" prefWidth="320.0" promptText="Tìm kiếm phiên đấu giá..." style="-fx-background-color: #131a39; -fx-text-fill: white; -fx-prompt-text-fill: #6e84ac; -fx-background-radius: 8; -fx-border-color: #27305c; -fx-border-radius: 8;" />

                        <Region HBox.hgrow="ALWAYS" /> <ComboBox fx:id="statusFilter" prefHeight="35.0" prefWidth="280.0" promptText="Lọc theo trạng thái" style="-fx-background-color: #131a39; -fx-background-radius: 8; -fx-border-color: #27305c; -fx-border-radius: 8;" />
                     </children>
                  </HBox>

                  <TableView fx:id="auctionTableView" style="-fx-background-color: transparent; -fx-border-color: #27305c; -fx-border-radius: 10; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colName" prefWidth="150.0" text="Tên phiên" />
                        <TableColumn fx:id="colId" prefWidth="80.0" text="Mã phiên" />
                        <TableColumn fx:id="colType" prefWidth="120.0" text="Loại sản phẩm" />
                        <TableColumn fx:id="colStartTime" prefWidth="130.0" text="Bắt đầu lúc" />
                        <TableColumn fx:id="colRemainingTime" prefWidth="120.0" text="Thời gian còn lại" />
                        <TableColumn fx:id="colStatus" prefWidth="110.0" text="Trạng thái" />
                        <TableColumn fx:id="colStartPrice" prefWidth="120.0" text="Giá khởi điểm" />
                        <TableColumn fx:id="colParticipants" prefWidth="120.0" text="Số người tham gia" />
                        <TableColumn fx:id="colAction" prefWidth="100.0" text="Hành động" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</StackPane>