<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane
        maxHeight="-Infinity" maxWidth="-Infinity"
        minHeight="-Infinity" minWidth="-Infinity"
        prefHeight="816.0" prefWidth="959.0"
        style="-fx-background-color: #1c254b;"
        styleClass="my-custom-node"
        stylesheets="@../style/nen.css"
        xmlns="http://javafx.com/javafx/25"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.mycompany.controller.ProfileController">

   <children>

      <!-- Sidebar -->
      <fx:include source="NavbarComponent.fxml" StackPane.alignment="TOP_LEFT" />

      <!-- Main content -->
      <VBox alignment="TOP_LEFT" spacing="0"
            style="-fx-padding: 40 48 32 48;"
            StackPane.alignment="TOP_LEFT">
         <StackPane.margin><Insets left="240.0" /></StackPane.margin>

         <!-- Page title -->
         <Label text="Hồ Sơ Cá Nhân"
                style="-fx-text-fill: #ffffff; -fx-font-size: 28px; -fx-font-weight: bold; -fx-font-family: 'Montserrat';">
            <VBox.margin><Insets bottom="4.0" /></VBox.margin>
         </Label>
         <Label text="Xem và cập nhật thông tin tài khoản của bạn"
                style="-fx-text-fill: rgba(182,191,255,0.55); -fx-font-size: 13px; -fx-font-family: 'Montserrat';">
            <VBox.margin><Insets bottom="28.0" /></VBox.margin>
         </Label>

         <!-- Two-column layout -->
         <HBox spacing="24" alignment="TOP_LEFT" VBox.vgrow="ALWAYS">

            <!-- LEFT: Avatar card -->
            <VBox spacing="0" alignment="TOP_CENTER"
                  style="-fx-background-color: rgba(255,255,255,0.05);
                             -fx-background-radius: 18;
                             -fx-border-color: rgba(255,255,255,0.09);
                             -fx-border-radius: 18;
                             -fx-border-width: 1;
                             -fx-padding: 32 28 28 28;"
                  minWidth="220" maxWidth="220">

               <!-- Avatar circle -->
               <StackPane fx:id="avatarContainer"
                          prefWidth="110" prefHeight="110"
                          style="-fx-background-radius: 55;
                                      -fx-border-color: rgba(238,116,85,0.5);
                                      -fx-border-radius: 55;
                                      -fx-border-width: 2.5;">
                  <VBox.margin><Insets bottom="16.0" /></VBox.margin>
                  <ImageView fx:id="avatarPicture"
                             fitHeight="110" fitWidth="110"
                             onMouseClicked="#onClickedChangeAvatar"
                             pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@../image/default_avatar.jpg" /></image>
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                  </ImageView>
               </StackPane>

               <Label text="Nhấn để đổi ảnh"
                      style="-fx-text-fill: rgba(182,191,255,0.45); -fx-font-size: 11px; -fx-font-family: 'Montserrat';">
                  <VBox.margin><Insets bottom="24.0" /></VBox.margin>
               </Label>

               <Region VBox.vgrow="ALWAYS" />

               <!-- Change password button -->
               <Button fx:id="changePasswordButton"
                       text="Đổi mật khẩu"
                       onAction="#onClickedChangePassword"
                       prefHeight="42.0" prefWidth="999.0"
                       styleClass="my-custom-button"
                       stylesheets="@../style/nen.css"
                       style="-fx-max-width: Infinity; -fx-font-size: 13px;">
                  <cursor><Cursor fx:constant="HAND" /></cursor>
               </Button>
            </VBox>

            <!-- RIGHT: Info card -->
            <VBox spacing="20" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: rgba(255,255,255,0.05);
                             -fx-background-radius: 18;
                             -fx-border-color: rgba(255,255,255,0.09);
                             -fx-border-radius: 18;
                             -fx-border-width: 1;
                             -fx-padding: 28 28 28 28;">

               <!-- Card header -->
               <HBox alignment="CENTER_LEFT" spacing="10">
                  <Label text="👤" style="-fx-font-size: 18px;" />
                  <Label text="Thông tin cá nhân"
                         style="-fx-text-fill: #ffffff; -fx-font-size: 15px;
                                      -fx-font-weight: bold; -fx-font-family: 'Montserrat';" />
               </HBox>

               <!-- Divider -->
               <Region prefHeight="1" maxHeight="1"
                       style="-fx-background-color: rgba(255,255,255,0.09);" />

               <!-- Username row -->
               <VBox spacing="8">
                  <Label text="Tên người dùng"
                         style="-fx-text-fill: rgba(182,191,255,0.65); -fx-font-size: 11px;
                                      -fx-font-weight: bold; -fx-font-family: 'Montserrat';" />
                  <HBox spacing="10" alignment="CENTER_LEFT">
                     <TextField fx:id="nameField"
                                editable="false"
                                prefHeight="42.0"
                                HBox.hgrow="ALWAYS"
                                styleClass="my-custom-text"
                                stylesheets="@../style/nen.css"
                                style="-fx-font-size: 14px; -fx-font-family: 'Montserrat';">
                        <cursor><Cursor fx:constant="TEXT" /></cursor>
                     </TextField>
                     <ImageView fx:id="nameEditBtn"
                                fitHeight="20" fitWidth="20"
                                onMouseClicked="#onClickedEditName"
                                pickOnBounds="true" preserveRatio="true"
                                style="-fx-opacity: 0.65;">
                        <image><Image url="@../image/pen.png" /></image>
                        <cursor><Cursor fx:constant="HAND" /></cursor>
                     </ImageView>
                  </HBox>
               </VBox>

               <!-- Email row (read-only, no edit) -->
               <VBox spacing="8">
                  <Label text="Email"
                         style="-fx-text-fill: rgba(182,191,255,0.65); -fx-font-size: 11px;
                                      -fx-font-weight: bold; -fx-font-family: 'Montserrat';" />
                  <TextField fx:id="emailField"
                             editable="false"
                             prefHeight="42.0"
                             styleClass="my-custom-text"
                             stylesheets="@../style/nen.css"
                             style="-fx-font-size: 14px; -fx-font-family: 'Montserrat';
                                          -fx-max-width: Infinity;">
                     <cursor><Cursor fx:constant="TEXT" /></cursor>
                  </TextField>
               </VBox>

               <!-- Ngày sinh row (read-only) -->
               <VBox spacing="8">
                  <Label text="Ngày sinh"
                         style="-fx-text-fill: rgba(182,191,255,0.65); -fx-font-size: 11px;
                                      -fx-font-weight: bold; -fx-font-family: 'Montserrat';" />
                  <TextField fx:id="birthField"
                             editable="false"
                             prefHeight="42.0"
                             styleClass="my-custom-text"
                             stylesheets="@../style/nen.css"
                             style="-fx-font-size: 14px; -fx-font-family: 'Montserrat';
                                          -fx-max-width: Infinity;">
                     <cursor><Cursor fx:constant="TEXT" /></cursor>
                  </TextField>
               </VBox>

               <!-- Địa chỉ row -->
               <VBox spacing="8">
                  <Label text="Địa chỉ"
                         style="-fx-text-fill: rgba(182,191,255,0.65); -fx-font-size: 11px;
                                      -fx-font-weight: bold; -fx-font-family: 'Montserrat';" />
                  <HBox spacing="10" alignment="CENTER_LEFT">
                     <TextField fx:id="addressField"
                                editable="false"
                                prefHeight="42.0"
                                HBox.hgrow="ALWAYS"
                                styleClass="my-custom-text"
                                stylesheets="@../style/nen.css"
                                style="-fx-font-size: 14px; -fx-font-family: 'Montserrat';">
                        <cursor><Cursor fx:constant="TEXT" /></cursor>
                     </TextField>
                     <ImageView fx:id="addressEditBtn"
                                fitHeight="20" fitWidth="20"
                                onMouseClicked="#onClickedEditAddress"
                                pickOnBounds="true" preserveRatio="true"
                                style="-fx-opacity: 0.65;">
                        <image><Image url="@../image/pen.png" /></image>
                        <cursor><Cursor fx:constant="HAND" /></cursor>
                     </ImageView>
                  </HBox>
               </VBox>

               <!-- Số điện thoại row -->
               <VBox spacing="8">
                  <Label text="Số điện thoại"
                         style="-fx-text-fill: rgba(182,191,255,0.65); -fx-font-size: 11px;
                                      -fx-font-weight: bold; -fx-font-family: 'Montserrat';" />
                  <HBox spacing="10" alignment="CENTER_LEFT">
                     <TextField fx:id="phoneField"
                                editable="false"
                                prefHeight="42.0"
                                HBox.hgrow="ALWAYS"
                                styleClass="my-custom-text"
                                stylesheets="@../style/nen.css"
                                style="-fx-font-size: 14px; -fx-font-family: 'Montserrat';">
                        <cursor><Cursor fx:constant="TEXT" /></cursor>
                     </TextField>
                     <ImageView fx:id="phoneEditBtn"
                                fitHeight="20" fitWidth="20"
                                onMouseClicked="#onClickedEditPhone"
                                pickOnBounds="true" preserveRatio="true"
                                style="-fx-opacity: 0.65;">
                        <image><Image url="@../image/pen.png" /></image>
                        <cursor><Cursor fx:constant="HAND" /></cursor>
                     </ImageView>
                  </HBox>
               </VBox>

               <Region VBox.vgrow="ALWAYS" />

               <!-- Save button -->
               <Button fx:id="saveButton"
                       text="Lưu thay đổi"
                       onAction="#onClickedSaveButton"
                       prefHeight="44.0" prefWidth="999.0"
                       styleClass="my-custom-button"
                       stylesheets="@../style/nen.css"
                       style="-fx-max-width: Infinity; -fx-font-size: 14px;">
                  <cursor><Cursor fx:constant="HAND" /></cursor>
               </Button>

            </VBox>
         </HBox>
      </VBox>

   </children>
</StackPane>
